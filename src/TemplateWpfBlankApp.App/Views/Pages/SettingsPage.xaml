<UserControl x:Class="TemplateWpfBlankApp.App.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Profile name" />
                    <TextBox Grid.Column="1" Text="{Binding Profile.ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="Environment" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Profile.EnvironmentName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4" FontWeight="SemiBold" Text="User alias" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Profile.UserAlias, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="6" FontWeight="SemiBold" Text="Default page" />
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Profile.DefaultPage, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="8" FontWeight="SemiBold" Text="Log level" />
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Profile.LogLevel, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Grid.Row="10" Grid.ColumnSpan="2">
                        <TextBlock FontWeight="SemiBold" Text="Visible columns" />
                        <TextBox Margin="0,8,0,0" Text="{Binding Profile.VisibleColumns, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,12,0,0" Content="Default to read-only mode" IsChecked="{Binding Profile.UseReadOnlyMode}" />
                        <TextBlock Margin="0,14,0,0" Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap"
                                   Text="The current profile snapshot is stored as JSON so each internal app can ship sensible defaults and let users keep environment-specific variations." />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding LoadCurrentCommand}" Content="Load Current" />
                        <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding SaveCurrentCommand}" Content="Save Current" />
                        <Button Padding="14,8" Command="{Binding ResetTemplateCommand}" Content="Reset Template" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Storage" />
                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding StorageFolderPath}" TextWrapping="Wrap" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
