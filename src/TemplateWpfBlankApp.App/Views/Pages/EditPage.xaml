<UserControl x:Class="TemplateWpfBlankApp.App.Views.Pages.EditPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding NewItemCommand}" Content="New Item" />
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding DeleteOrDeactivateCommand}" Content="Delete / Deactivate" />
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding ResetCommand}" Content="Reset" />
                    <Button Padding="14,8" Command="{Binding SaveCommand}" Content="Save" />
                </StackPanel>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="{Binding ModeTitle}" />
                    <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="Required fields are validated before save. Existing read-only rows stay locked." />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding ValidationMessage}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="{Binding DeleteConfirmationRequested, StringFormat=Delete confirmation requested: {0}}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="{Binding IsReadOnlyItem, StringFormat=Read-only editing disabled: {0}}" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Record ID" />
                    <TextBox Grid.Column="1" IsReadOnly="True" Text="{Binding CurrentItem.Id}" />

                    <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="Title" />
                    <TextBox Grid.Row="2" Grid.Column="1" IsReadOnly="{Binding IsReadOnlyItem}" Text="{Binding CurrentItem.Title, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4" FontWeight="SemiBold" Text="Source system" />
                    <TextBox Grid.Row="4" Grid.Column="1" IsReadOnly="{Binding IsReadOnlyItem}" Text="{Binding CurrentItem.SourceSystem, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="6" FontWeight="SemiBold" Text="Owner" />
                    <TextBox Grid.Row="6" Grid.Column="1" IsReadOnly="{Binding IsReadOnlyItem}" Text="{Binding CurrentItem.Owner, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="8" FontWeight="SemiBold" Text="Status" />
                    <TextBox Grid.Row="8" Grid.Column="1" IsReadOnly="{Binding IsReadOnlyItem}" Text="{Binding CurrentItem.Status, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="10" FontWeight="SemiBold" Text="Notes" VerticalAlignment="Top" />
                    <StackPanel Grid.Row="10" Grid.Column="1">
                        <TextBox Height="160"
                                 AcceptsReturn="True"
                                 IsReadOnly="{Binding IsReadOnlyItem}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding CurrentItem.Notes, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Margin="0,12,0,0" Content="Row is read-only" IsChecked="{Binding CurrentItem.IsReadOnly}" IsEnabled="False" />
                        <CheckBox Margin="0,8,0,0" Content="Row is active" IsChecked="{Binding CurrentItem.IsActive}" IsEnabled="{Binding IsCreatingNewItem}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
