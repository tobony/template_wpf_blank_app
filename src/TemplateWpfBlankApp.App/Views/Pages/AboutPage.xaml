<UserControl x:Class="TemplateWpfBlankApp.App.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Application metadata" />
                <TextBlock Margin="0,12,0,0" Text="Version" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Version}" />
                <TextBlock Margin="0,12,0,0" Text="Build info" FontWeight="SemiBold" />
                <TextBlock Text="{Binding BuildInformation}" />
                <TextBlock Margin="0,12,0,0" Text="Deployment channel" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DeploymentChannel}" />
                <TextBlock Margin="0,12,0,0" Text="Support contact" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SupportContact}" />
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Licensing / open source" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Text="{Binding LicenseNotice}" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Text="{Binding OpenSourceNotice}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
