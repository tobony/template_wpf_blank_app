<UserControl x:Class="TemplateWpfBlankApp.App.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <StackPanel>
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Template metadata" />
                <TextBlock Margin="0,12,0,0" Text="Version" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Version}" />
                <TextBlock Margin="0,12,0,0" Text="Support contact" FontWeight="SemiBold" />
                <TextBlock Text="{Binding SupportContact}" />
                <TextBlock Margin="0,12,0,0" Text="Deployment model" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" Text="{Binding DeploymentModel}" />
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Recommended extension points" />
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap"
                           Text="Replace the mock connection and workspace services with business-specific adapters for SQL, SharePoint, Microsoft Graph, or Power BI. Keep the shell, settings, and logging infrastructure as shared building blocks across internal apps." />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
