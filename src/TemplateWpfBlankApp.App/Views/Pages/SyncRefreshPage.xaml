<UserControl x:Class="TemplateWpfBlankApp.App.Views.Pages.SyncRefreshPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding ReloadFromServerCommand}" Content="Reload From Server" />
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding PushLocalChangesCommand}" Content="Push Local Changes" />
                    <Button Padding="14,8" Command="{Binding RetryFailedCommand}" Content="Retry Failed Queue" />
                </StackPanel>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Sync status" />
                    <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding SyncStatusMessage}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="{Binding LastServerRefreshAt, StringFormat=Last server refresh: {0:yyyy-MM-dd HH:mm:ss}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Conflict list" />
                    <DataGrid Margin="0,12,0,0"
                              ItemsSource="{Binding Conflicts}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding WorkItemId}" Width="70" />
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemTitle}" Width="*" />
                            <DataGridTextColumn Header="Local" Binding="{Binding LocalValue}" Width="*" />
                            <DataGridTextColumn Header="Remote" Binding="{Binding RemoteValue}" Width="*" />
                            <DataGridTextColumn Header="Hint" Binding="{Binding ResolutionHint}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Retry queue" />
                    <DataGrid Margin="0,12,0,0"
                              ItemsSource="{Binding FailedItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding WorkItemId}" Width="70" />
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemTitle}" Width="*" />
                            <DataGridTextColumn Header="Remote issue" Binding="{Binding RemoteValue}" Width="*" />
                            <DataGridCheckBoxColumn Header="Retry" Binding="{Binding CanRetry}" Width="80" />
                            <DataGridTextColumn Header="Hint" Binding="{Binding ResolutionHint}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
