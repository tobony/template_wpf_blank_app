<Application x:Class="TemplateWpfBlankApp.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:TemplateWpfBlankApp.App.ViewModels"
             xmlns:views="clr-namespace:TemplateWpfBlankApp.App.Views.Pages">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF7F8FA" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="White" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FFE1E4EA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0F6CBD" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#FF5F6B7A" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <DataTemplate DataType="{x:Type viewModels:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:DataViewPageViewModel}">
            <views:DataViewPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EditPageViewModel}">
            <views:EditPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:BulkUpdatePageViewModel}">
            <views:BulkUpdatePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SyncRefreshPageViewModel}">
            <views:SyncRefreshPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConnectionsPageViewModel}">
            <views:ConnectionsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
            <views:SettingsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SavedProfilesPageViewModel}">
            <views:SavedProfilesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:LogsPageViewModel}">
            <views:LogsPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AboutPageViewModel}">
            <views:AboutPage />
        </DataTemplate>
    </Application.Resources>
</Application>
