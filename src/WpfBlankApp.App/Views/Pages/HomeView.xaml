<UserControl x:Class="WpfBlankApp.App.Views.Pages.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Quick actions" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Start common view, create, connection, and support workflows from the template home page." />
                        <UniformGrid Margin="0,14,0,0" Columns="2">
                            <Button Margin="0,0,8,8" Padding="14,10" Command="{Binding OpenDataViewCommand}" Content="Open Data View" />
                            <Button Margin="0,0,0,8" Padding="14,10" Command="{Binding CreateNewItemCommand}" Content="New Record" />
                            <Button Margin="0,0,8,0" Padding="14,10" Command="{Binding OpenConnectionsCommand}" Content="Test Connections" />
                            <Button Padding="14,10" Command="{Binding OpenLogsCommand}" Content="Open Logs" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Recent activity (last 10)" />
                        <ListBox Margin="0,12,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemsSource="{Binding RecentActivities}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Severity}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Message}" />
                                                <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding Category}" />
                                                <TextBlock FontSize="12"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Connection status summary" />
                        <UniformGrid Margin="0,12,0,0" Columns="3">
                            <Border Margin="0,0,8,0" Padding="12" Background="#FFE9F2FB" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Connected" />
                                    <TextBlock FontSize="24" Text="{Binding ConnectedCount}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,8,0" Padding="12" Background="#FFFFF4D9" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Warning" />
                                    <TextBlock FontSize="24" Text="{Binding AttentionCount}" />
                                </StackPanel>
                            </Border>
                            <Border Padding="12" Background="#FFFDE7E9" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Error" />
                                    <TextBlock FontSize="24" Text="{Binding ErrorCount}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Active profile" />
                        <TextBlock Margin="0,12,0,0" Text="{Binding Profile.ProfileName}" />
                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding Profile.EnvironmentName}" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Primary / advanced navigation" />
                        <TextBlock Text="{Binding Profile.ShowAdvancedPages, StringFormat=Advanced pages enabled: {0}}" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Administrator mode" />
                        <TextBlock Text="{Binding Profile.IsAdministrator, StringFormat=Administrator access: {0}}" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Visible columns" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding Profile.VisibleColumns}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
