<UserControl x:Class="WpfBlankApp.App.Views.Pages.SavedProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding RefreshCommand}" Content="Refresh" />
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding SaveAsCommand}" Content="Save As" />
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding LoadCommand}" Content="Load" />
                    <Button Margin="0,0,8,0" Padding="14,8" Command="{Binding SetFavoriteCommand}" Content="Set Favorite" />
                    <Button Padding="14,8" Command="{Binding DeleteCommand}" Content="Delete" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0">
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding ProfileName}" />
                                    <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding EnvironmentName}" />
                                    <TextBlock Text="{Binding IsFavorite, StringFormat=Favorite: {0}}" />
                                    <TextBlock Text="{Binding LastUsedAt, StringFormat='Last used: {0:yyyy-MM-dd HH:mm}'}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Recent profiles" />
                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding RecentProfiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ProfileName}" />
                                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding EnvironmentName}" />
                                        <TextBlock Text="{Binding LastUsedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
