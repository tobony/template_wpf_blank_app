<Window x:Class="WpfBlankApp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="820"
        Width="1400"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="Internal Tool Shell" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="WPF template for SSO-connected business apps" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Current profile" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding Profile.ProfileName}" />
                            <TextBlock Foreground="{StaticResource SubtleTextBrush}" Text="{Binding Profile.EnvironmentName}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Padding="14"
                                                Background="Transparent"
                                                CornerRadius="10">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF2F6FB" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFE9F2FB" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="18" Text="{Binding Icon}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Text="{Binding ViewModel.Description}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0">
                <DockPanel>
                    <StackPanel>
                        <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding CurrentPage.Title}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="{Binding CurrentPage.Description}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>

            <Border Grid.Row="4"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="Ready for extension: SQL / SharePoint / Graph / Power BI" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
